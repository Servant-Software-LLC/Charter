<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hardened-runtime entitlements for the self-contained .NET single-file binary. These are the
  exceptions a .NET app typically needs under the hardened runtime that notarization requires
  (JIT, unsigned executable memory, loading the extracted native libs, reading DOTNET_*/dyld vars).
  Trim these down later if a stricter set still notarizes cleanly.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
